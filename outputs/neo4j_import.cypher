// Run in Neo4j Browser or cypher-shell.
CREATE CONSTRAINT kg_node_id IF NOT EXISTS FOR (n:KGNode) REQUIRE n.id IS UNIQUE;
MERGE (n:KGNode:Paper {id: "paper:sample_paper"}) SET n += {id: "paper:sample_paper", label: "Example Paper Title", type: "Paper", paper_id: "sample_paper", year: ""};
MERGE (n:KGNode:Method {id: "method:lightweight_attention_message_passing"}) SET n += {id: "method:lightweight_attention_message_passing", label: "lightweight attention message passing", type: "Method", paper_id: "", year: ""};
MERGE (n:KGNode:Dataset {id: "dataset:cora"}) SET n += {id: "dataset:cora", label: "Cora", type: "Dataset", paper_id: "", year: ""};
MERGE (n:KGNode:Dataset {id: "dataset:citeseer"}) SET n += {id: "dataset:citeseer", label: "Citeseer", type: "Dataset", paper_id: "", year: ""};
MERGE (n:KGNode:Baseline {id: "baseline:gcn"}) SET n += {id: "baseline:gcn", label: "GCN", type: "Baseline", paper_id: "", year: ""};
MERGE (n:KGNode:Baseline {id: "baseline:graphsage"}) SET n += {id: "baseline:graphsage", label: "GraphSAGE", type: "Baseline", paper_id: "", year: ""};
MERGE (n:KGNode:Metric {id: "metric:accuracy"}) SET n += {id: "metric:accuracy", label: "Accuracy", type: "Metric", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:abstract"}) SET n += {id: "keyword:abstract", label: "abstract", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:accuracy"}) SET n += {id: "keyword:accuracy", label: "accuracy", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:aggregation"}) SET n += {id: "keyword:aggregation", label: "aggregation", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:approach"}) SET n += {id: "keyword:approach", label: "approach", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:architecture"}) SET n += {id: "keyword:architecture", label: "architecture", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:attention"}) SET n += {id: "keyword:attention", label: "attention", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:baselines"}) SET n += {id: "keyword:baselines", label: "baselines", type: "Keyword", paper_id: "", year: ""};
MERGE (n:KGNode:Keyword {id: "keyword:benchmarks"}) SET n += {id: "keyword:benchmarks", label: "benchmarks", type: "Keyword", paper_id: "", year: ""};
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "method:lightweight_attention_message_passing"}) MERGE (a)-[:PROPOSES]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "dataset:cora"}) MERGE (a)-[:USES]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "dataset:citeseer"}) MERGE (a)-[:USES]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "baseline:gcn"}) MERGE (a)-[:COMPARES_WITH]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "baseline:graphsage"}) MERGE (a)-[:COMPARES_WITH]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "metric:accuracy"}) MERGE (a)-[:EVALUATED_BY]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:abstract"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:accuracy"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:aggregation"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:approach"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:architecture"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:attention"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:baselines"}) MERGE (a)-[:RELATED_TO]->(b);
MATCH (a:KGNode {id: "paper:sample_paper"}), (b:KGNode {id: "keyword:benchmarks"}) MERGE (a)-[:RELATED_TO]->(b);
